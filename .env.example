# Recomendador de Filmes - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais

# ==========================================
# CONFIGURAÇÕES DA API
# ==========================================

# Host da API (0.0.0.0 para localhost)
API_HOST=0.0.0.0

# Porta da API (8000 para desenvolvimento)
API_PORT=8000

# Modo de debug (True para desenvolvimento, False para produção)
DEBUG=True

# URL base da API (gerado automaticamente com HOST e PORT)
# BASE_URL=http://${API_HOST}:${API_PORT}

# ==========================================
# CONFIGURAÇÕES DE MACHINE LEARNING
# ==========================================

# Tipo de modelo a ser usado (collaborative, content-based, hybrid)
MODEL_TYPE=collaborative

# Caminho para salvar os modelos treinados
MODEL_PATH=./models/

# Habilitar cache de recomendações (True/False)
CACHE_ENABLED=True

# Tempo de vida do cache em segundos (3600 = 1 hora)
CACHE_TTL=3600

# Número máximo de recomendações por requisição (1-20)
MAX_RECOMMENDATIONS=20

# Algoritmo de recomendação padrão (knn, svd, nmf)
DEFAULT_ALGORITHM=knn

# Número de vizinhos para KNN (5-50)
KNN_NEIGHBORS=10

# Número de componentes para SVD (5-100)
SVD_COMPONENTS=20

# Número de tópicos para NMF (5-50)
NMF_TOPICS=10

# ==========================================
# CONFIGURAÇÕES DE BANCO DE DADOS
# ==========================================

# URL do banco de dados SQLite
DATABASE_URL=sqlite:///./movies.db

# Habilitar logging de queries SQL (True/False)
SQLALCHEMY_LOG_QUERIES=False

# Pool size para conexões do banco de dados
DB_POOL_SIZE=5

# Timeout para conexões do banco de dados (em segundos)
DB_TIMEOUT=30

# ==========================================
# CONFIGURAÇÕES DE LOGGING
# ==========================================

# Nível de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Formato dos logs (text, json)
LOG_FORMAT=json

# Caminho para salvar os logs
LOG_FILE=./logs/app.log

# Habilitar logs em arquivo (True/False)
LOG_TO_FILE=True

# Habilitar logs no console (True/False)
LOG_TO_CONSOLE=True

# ==========================================
# CONFIGURAÇÕES DE ANALYTICS
# ==========================================

# Habilitar coleta de métricas (True/False)
ANALYTICS_ENABLED=True

# Habilitar A/B testing (True/False)
AB_TESTING_ENABLED=False

# Percentual de tráfego para variante B (0.0-1.0)
AB_TEST_TRAFFIC_SPLIT=0.5

# ==========================================
# CONFIGURAÇÕES DE DEPLOY
# ==========================================

# Ambiente (development, staging, production)
ENVIRONMENT=development

# URL do frontend (se houver)
FRONTEND_URL=

# CORS origins (separados por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# CONFIGURAÇÕES DE SEGURANÇA
# ==========================================

# Chave secreta para assinatura de tokens (gerar uma aleatória)
SECRET_KEY=your-secret-key-here-change-in-production

# Tempo de expiração do token em minutos
TOKEN_EXPIRE_MINUTES=60

# Habilitar rate limiting (True/False)
RATE_LIMIT_ENABLED=True

# Número máximo de requisições por minuto
RATE_LIMIT_PER_MINUTE=60

# ==========================================
# CONFIGURAÇÕES DE EXTERNAL APIS
# ==========================================

# API Key do TMDB (opcional)
TMDB_API_KEY=

# API Key do IMDB (opcional)
IMDB_API_KEY=

# URL da API de filmes externa
EXTERNAL_MOVIE_API_URL=

# ==========================================
# NOTAS
# ==========================================

# 1. NUNCA comite este arquivo com credenciais reais
# 2. Adicione .env ao seu .gitignore
# 3. Gere chaves seguras para produção
# 4. Use variáveis de ambiente em produção
# 5. Rotacione chaves secretas regularmente
# 6. Mantenha este arquivo privado

# ==========================================
# EXEMPLOS DE CONFIGURAÇÃO
# ==========================================

# Desenvolvimento local:
# API_HOST=0.0.0.0
# API_PORT=8000
# DEBUG=True
# CACHE_ENABLED=True
# LOG_LEVEL=DEBUG

# Produção:
# API_HOST=0.0.0.0
# API_PORT=8000
# DEBUG=False
# CACHE_ENABLED=True
# LOG_LEVEL=INFO
# ENVIRONMENT=production
